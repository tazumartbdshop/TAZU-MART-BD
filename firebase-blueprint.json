{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile metadata",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Folder": {
      "title": "Indexed Item",
      "description": "User's file folder or indexed file metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["folder", "file"] },
        "size": { "type": "string" },
        "folderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "File": {
      "title": "File",
      "description": "User's file metadata",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "folderId": { "type": "string" },
        "size": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "User's personal note",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "User's team member information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/folders/{folderId}": {
      "schema": "Folder",
      "description": "Folder and File metadata collection"
    },
    "/users/{userId}/notes/{noteId}": {
      "schema": "Note",
      "description": "Notes content collection"
    },
    "/users/{userId}/teamMembers/{memberId}": {
      "schema": "TeamMember",
      "description": "Team members collection"
    }
  }
}
