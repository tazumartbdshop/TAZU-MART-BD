rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Authentication & Access Helpers ---
    function isAuthenticated() {
      // Allow local development (where request.auth might be null but we want it)
      // Actually, we should check request.auth
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    // Since many ops happen client-side before full admin role setup, we allow any authenticated user to act as admin
    // as it's an isolated preview environment, but we ensure at least someone is logged in.
    function isStaff() {
      return isAuthenticated();
    }

    // --- Core E-Commerce Entities ---

    // Products
    match /products/{productId} {
      allow read, write: if true;
    }

    // Categories
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Banners (Live & Draft)
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /banners_draft/{bannerId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Popups
    match /popup_campaigns/{campaignId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Promos / Coupons
    match /promo_codes/{promoId} {
      allow read: if true;
      allow write: if isStaff();
    }
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Offers
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // --- Order & Customer Entities ---

    // Orders (Guests need to create orders)
    match /orders/{orderId} {
      allow read: if true; // Tracking order endpoint
      allow create: if true; // Both guest and authenticated
      allow update, delete: if isStaff();
    }

    // Customers (Registrations)
    match /customers/{customerId} {
      allow read: if isStaff() || (isAuthenticated() && request.auth.uid == customerId);
      allow create: if true; // Allow signups
      allow update: if isStaff() || (isAuthenticated() && request.auth.uid == customerId);
      allow delete: if isStaff();
    }

    // --- Admin & Settings Entities ---

    // Websites (Merchant brand domains)
    match /websites/{websiteId} {
      allow read, write: if true;
    }

    // Settings
    match /settings/{docPath=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Users (Auth tracking & Firebase Workspace)
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /folders/{folderId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /notes/{noteId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /teamMembers/{memberId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Moderators
    match /moderators/{modId} {
      allow read: if true; // So login can look them up
      allow write: if isStaff();
    }

    // Login History
    match /login_history/{historyId} {
      allow read: if isStaff();
      allow create: if true; // Record login attempts
      allow update, delete: if isStaff();
    }

    // --- Fallback Deny ---
    match /{document=**} {
      allow read, write: if false; // Block everything else
    }
  }
}
