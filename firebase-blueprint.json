{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "E-commerce product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "stock": { "type": "number" },
        "status": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "variants": { "type": "array" },
        "seoData": { "type": "object" },
        "reviews": { "type": "array" }
      },
      "required": ["id", "name"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "bannerImage": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Hero, categories, promo or popup banners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "title"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "customerId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Store customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupon",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "code"]
    },
    "WebsiteSettings": {
      "title": "Website Settings",
      "description": "Global website settings, including logo, favicon, about us, contact",
      "type": "object",
      "properties": {
        "logo": { "type": "string" },
        "favicon": { "type": "string" },
        "aboutUs": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "privacyPolicy": { "type": "string" },
        "termsConditions": { "type": "string" },
        "shippingSettings": { "type": "object" },
        "paymentSettings": { "type": "object" },
        "homepageSettings": { "type": "object" },
        "footerSettings": { "type": "object" },
        "adminSettings": { "type": "object" }
      },
      "required": []
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Store categories"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Store banners"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Store orders"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Store customers"
    },
    "/coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Store coupons"
    },
    "/settings/global": {
      "schema": "WebsiteSettings",
      "description": "Global website configurations"
    }
  }
}
